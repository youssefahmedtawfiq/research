void setup() {
  // تشغيل الاتصال التسلسلي بسرعة 9600
  Serial.begin(9600);
  
  // لضمان عشوائية الأرقام في كل مرة يشتغل فيها الأردوينو
  randomSeed(analogRead(0));
}

void loop() {
  // توليد 12 رقم
  for (int i = 0; i < 12; i++) {
    // توليد رقم عشوائي بين 10 و 50
    // ملاحظة: random(min, max) في الأردوينو لا تشمل الرقم الأقصى، لذا نكتب 51
    int tempValue = random(10, 51);
    
    // طباعة الرقم
    Serial.print(tempValue);
    
    // طباعة مسافة بعد كل رقم ما عدا الأخير
    if (i < 11) {
      Serial.print(" ");
    }
  }
  
  // سطر جديد بعد انتهاء الـ 12 رقم
  Serial.println();
  
  // انتظار ثانية قبل الإرسال القادم (يمكنك تقليلها حسب رغبتك)
  delay(500);
}